{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "accelerator.interconnect_fault",
  "title": "accelerator.interconnect_fault",
  "description": "Interconnect fault on an intra- or inter-node link.",
  "type": "object",
  "properties": {
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "degraded",
        "critical"
      ]
    },
    "confidence": {
      "type": "number"
    },
    "device": {
      "type": "object",
      "properties": {
        "vendor": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "device_id": {
          "type": "string"
        },
        "host_id": {
          "type": "string"
        }
      },
      "required": [
        "vendor",
        "model",
        "device_id",
        "host_id"
      ],
      "additionalProperties": false
    },
    "topology": {
      "type": "object",
      "properties": {
        "link_type": {
          "type": "string",
          "enum": [
            "nvlink",
            "xgmi",
            "pcie",
            "infiniband",
            "roce"
          ]
        },
        "local_port": {
          "type": "string"
        },
        "peer_device_id": {
          "type": "string"
        },
        "fabric_domain": {
          "type": "string"
        }
      },
      "required": [
        "link_type",
        "local_port",
        "peer_device_id",
        "fabric_domain"
      ],
      "additionalProperties": false
    },
    "vendor_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        },
        "required": [
          "source",
          "code"
        ],
        "additionalProperties": false
      }
    },
    "normalized_effect": {
      "type": "object",
      "properties": {
        "communication_path": {
          "type": "string",
          "enum": [
            "ok",
            "degraded",
            "failed"
          ]
        },
        "compute_path": {
          "type": "string",
          "enum": [
            "ok",
            "degraded",
            "failed"
          ]
        },
        "memory_integrity": {
          "type": "string",
          "enum": [
            "ok",
            "degraded",
            "failed"
          ]
        },
        "bandwidth_impact": {
          "type": "string",
          "enum": [
            "none",
            "possible",
            "probable",
            "confirmed"
          ]
        },
        "job_correctness_risk": {
          "type": "string",
          "enum": [
            "none",
            "unknown",
            "low",
            "medium",
            "high"
          ]
        },
        "job_performance_risk": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        }
      },
      "required": [
        "communication_path",
        "compute_path",
        "memory_integrity",
        "bandwidth_impact",
        "job_correctness_risk",
        "job_performance_risk"
      ],
      "additionalProperties": false
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disallowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object",
      "properties": {
        "fault_class": {
          "type": "string",
          "enum": [
            "interconnect",
            "memory",
            "compute",
            "thermal",
            "firmware",
            "lifecycle"
          ]
        },
        "fault_domain": {
          "type": "string",
          "enum": [
            "device",
            "link",
            "host",
            "rack",
            "fabric"
          ]
        }
      },
      "required": [
        "fault_class",
        "fault_domain"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "severity",
    "confidence",
    "device",
    "topology",
    "vendor_evidence",
    "normalized_effect",
    "recommended_actions",
    "disallowed_actions",
    "labels"
  ],
  "additionalProperties": true
}
